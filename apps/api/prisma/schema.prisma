datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  firstName     String?
  lastName      String?
  password      String
  phoneNumber   String?
  accountNumber   String   @unique
  accountId       String   @unique
  bankAccountName String?
  bankName        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  plans           Plan[]
  transactions  Transaction[]
}

model Plan {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  // Common fields
  name           String
  description    String?
  savingType     String   // daily | weekly | monthly | yearly
  savingPlan     String   // vault | fantasy-savings
  amount         Float
  targetAmount   Float
  currentBalance Float    @default(0)
  startDate      DateTime
  endDate        DateTime
  debitSchedule  String   // e.g. "08:00 AM"
  nextDebitDate  DateTime

  // Fantasy-savings specific fields
  teamId          Int?
  teamName        String?
  nextFixtureId   Int?
  nextFixtureDate DateTime?

  // Nomba Direct Debit Mandate fields
  mandateId           String?
  merchantReference   String?
  mandateStatus       String?
  mandateAdviceStatus String?
  autoSaveEnabled     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id        String   @id @default(uuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float
  type      String   // deposit | auto-save
  status    String   @default("completed")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

